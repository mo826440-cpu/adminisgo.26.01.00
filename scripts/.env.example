# 1) Copiá este archivo a .env (el script SOLO lee scripts/.env, no .env.example):
#    copy .env.example .env
#
# 2) La URL de Supabase puede estar solo en frontend/.env como VITE_SUPABASE_URL.
#
# 3) La service_role la ves en Supabase → Project Settings → API (secreta; no subas .env a Git).

SUPABASE_SERVICE_ROLE_KEY=reemplazar_con_service_role_de_supabase

# ID en public.comercios
COMERCIO_ID=1

# Opcional si no usás frontend/.env para la URL:
# SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Opcional: ruta al dump MySQL
# CATEGORIAS_SQL=C:\2026\adminisgo.26.01.00\sql\categorias.sql
